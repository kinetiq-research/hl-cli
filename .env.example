# API Wallet private key (for write operations: orders, cancel, leverage, transfer)
# Create one at: Hyperliquid UI → Settings → API Wallets
# WARNING: Keep this secure. Never commit to version control.
HL_PRIVATE_KEY=0x...

# Wallet address (for read-only operations: state, positions, orders, fills)
HL_ADDRESS=0x...

# Network: mainnet or testnet (default: mainnet)
HL_NETWORK=mainnet
